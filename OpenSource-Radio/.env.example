# Exemple de configuration locale. Ne publiez jamais de valeurs réelles.

RADIO_USER=votreradio
RADIO_HOME=/home/votreradio
RADIO_ROOT=/home/votreradio/radio
MUSIC_ROOT=/home/votreradio/Musique
WEB_ROOT=/var/www/html

ICECAST_STATUS_URL=http://127.0.0.1:8000/admin/stats
ICECAST_ADMIN_USER=admin
ICECAST_ADMIN_PASSWORD=CHANGE_ME
ICECAST_SOURCE_PASSWORD=CHANGE_ME
ICECAST_TARGET_MOUNT=/stream.mp3

LIQUIDSOAP_HARBOR_PORT=18005
LIQUIDSOAP_HARBOR_PASSWORD=CHANGE_ME

PUBLIC_STREAM_URL=https://stream.votreradio.example/stream.mp3
PUBLIC_BASE_URL=https://stream.votreradio.example

