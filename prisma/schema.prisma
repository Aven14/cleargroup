generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CIVIL
  DRIVER
  CONTROLLER
  ADMIN
  SECURITY
  AMBULANCIER
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  passwordHash  String
  firstname     String
  lastname      String
  roles         UserRole[]    @default([CIVIL])
  createdAt     DateTime      @default(now())
  sessions      Session[]
  shifts        DriverShift[]
  issuedTickets Ticket[]      @relation("IssuedTickets")
  activityLogs  ActivityLog[] @relation("UserLogs")
  issuedBans    BusBan[]      @relation("IssuedBans")
  securityShifts SecurityServiceShift[]
  createdPatrols SecurityPatrol[] @relation("CreatedPatrols")
  patrolMember  SecurityPatrol[] @relation("PatrolMembers")
  createdAlerts SecurityAlert[]
  alertResponses SecurityAlertResponse[]
  createdDebriefings SecurityDebriefing[]
  detainedPersons SecurityDetainee[]
  rescueShifts RescueServiceShift[]
  createdRescuePatrols RescuePatrol[] @relation("CreatedRescuePatrols")
  rescuePatrolMember  RescuePatrol[] @relation("RescuePatrolMembers")
  createdRescueAlerts RescueAlert[]
  rescueAlertResponses RescueAlertResponse[]
  createdRescueDebriefings RescueDebriefing[]

  @@index([roles])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([expiresAt])
}

model Ticket {
  id          String   @id @default(cuid())
  firstname   String
  lastname    String
  ticketType  String
  issuedById  String?
  issuedBy    User?    @relation("IssuedTickets", fields: [issuedById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  expiresAt   DateTime @db.Timestamptz(3)
  cancelled   Boolean  @default(false)
  cancelledAt DateTime? @db.Timestamptz(3)

  @@index([firstname, lastname])
  @@index([expiresAt])
  @@index([issuedById])
  @@index([cancelled])
}

model TransportLine {
  id        String        @id @default(cuid())
  number    Int           @unique
  name      String
  color     String        @default("#1d4ed8")
  createdAt DateTime      @default(now())
  stops     Stop[]
  shifts    DriverShift[]
}

model Stop {
  id       String        @id @default(cuid())
  name     String
  slug     String
  audioUrl String
  order    Int           @default(0)
  lineId   String
  line     TransportLine @relation(fields: [lineId], references: [id], onDelete: Cascade)

  @@unique([lineId, slug])
}

model DriverShift {
  id               String        @id @default(cuid())
  userId           String
  lineId           String
  currentStopId    String?
  destinationStopId String?
  startedAt        DateTime      @default(now())
  endedAt          DateTime?
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  line             TransportLine @relation(fields: [lineId], references: [id], onDelete: Cascade)

  @@index([userId, endedAt])
  @@index([lineId, endedAt])
}

model LiveAnnouncement {
  id        String   @id @default(cuid())
  audioUrl  String
  label     String
  lineId    String
  createdAt DateTime @default(now())
  played    Boolean  @default(false)
  
  @@index([createdAt])
  @@index([played])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation("UserLogs", fields: [userId], references: [id], onDelete: SetNull)
  action    String
  entity    String?
  entityId  String?
  details   String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([entity])
}

model RadioState {
  id            String   @id @default(cuid())
  trackIndex    Int      @default(0)
  position      Float    @default(0)
  isPlaying     Boolean  @default(false)
  startedAt     BigInt?
  playlistOrder String[] @default([])
  lastSync      DateTime @default(now())

  @@index([lastSync])
}

model BusBan {
  id         String    @id @default(cuid())
  firstname  String
  lastname   String
  reason     String?
  bannedById String
  bannedBy   User      @relation("IssuedBans", fields: [bannedById], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  liftedAt   DateTime?

  @@index([firstname, lastname])
  @@index([liftedAt])
  @@index([createdAt])
}

model SecurityServiceShift {
  id          String   @id @default(cuid())
  userId      String
  vehicle     String?
  startedAt   DateTime @default(now())
  endedAt     DateTime?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, endedAt])
  @@index([endedAt])
}

model SecurityPatrol {
  id          String   @id @default(cuid())
  agentId     String
  coequipierId String?
  sector      String
  vehicle     String
  startedAt   DateTime @default(now())
  endedAt     DateTime?
  missionType String   @default("Patrouille mobile")
  observations String?
  maxAgents   Int      @default(2)
  additionalAgentIds String[] @default([])
  agent       User     @relation("CreatedPatrols", fields: [agentId], references: [id], onDelete: Cascade)
  coequipier   User?    @relation("PatrolMembers", fields: [coequipierId], references: [id], onDelete: SetNull)

  @@index([agentId, endedAt])
  @@index([endedAt])
}

model SecurityAlert {
  id              String   @id @default(cuid())
  type            String
  location        String
  description     String
  agentsRequested Int      @default(1)
  createdById     String
  active          Boolean  @default(true)
  closedAt        DateTime?
  createdAt       DateTime @default(now())
  createdBy       User     @relation(fields: [createdById], references: [id], onDelete: Cascade)
  responses       SecurityAlertResponse[]

  @@index([createdById, active])
  @@index([active])
  @@index([closedAt])
  @@index([createdAt])
}

model SecurityAlertResponse {
  id        String   @id @default(cuid())
  alertId   String
  userId    String
  respondedAt DateTime @default(now())
  alert     SecurityAlert @relation(fields: [alertId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([alertId])
  @@index([userId])
}

model SecurityDebriefing {
  id            String   @id @default(cuid())
  title         String
  date          DateTime @default(now())
  location      String
  agentsPresent String[]
  interventionType String
  summary       String
  procedure     String
  result        String
  incidents     String?
  observations  String?
  createdById   String
  createdBy     User     @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([createdById])
  @@index([date])
}

model SecurityDetainee {
  id              String   @id @default(cuid())
  firstname       String
  lastname        String
  enteredAt       DateTime @default(now())
  detentionTime   Int      @default(30)
  reason          String
  agentId         String
  releasedAt      DateTime?
  agent           User     @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId, releasedAt])
  @@index([releasedAt])
  @@index([enteredAt])
}

model SecurityEvent {
  id          String   @id @default(cuid())
  name        String
  date        DateTime
  startTime   String
  endTime     String
  description String
  location    String
  agentIds    String[]
  isPublic    Boolean  @default(true)

  @@index([date])
  @@index([isPublic])
}

model RescueServiceShift {
  id          String   @id @default(cuid())
  userId      String
  vehicle     String?
  startedAt   DateTime @default(now())
  endedAt     DateTime?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, endedAt])
  @@index([endedAt])
}

model RescuePatrol {
  id          String   @id @default(cuid())
  agentId     String
  coequipierId String?
  sector      String
  vehicle     String
  startedAt   DateTime @default(now())
  endedAt     DateTime?
  missionType String   @default("Intervention médicale")
  observations String?
  maxAgents   Int      @default(2)
  additionalAgentIds String[] @default([])
  agent       User     @relation("CreatedRescuePatrols", fields: [agentId], references: [id], onDelete: Cascade)
  coequipier   User?    @relation("RescuePatrolMembers", fields: [coequipierId], references: [id], onDelete: SetNull)

  @@index([agentId, endedAt])
  @@index([endedAt])
}

model RescueAlert {
  id              String   @id @default(cuid())
  type            String
  location        String
  description     String
  agentsRequested Int      @default(1)
  createdById     String
  active          Boolean  @default(true)
  closedAt        DateTime?
  createdAt       DateTime @default(now())
  createdBy       User     @relation(fields: [createdById], references: [id], onDelete: Cascade)
  responses       RescueAlertResponse[]

  @@index([createdById, active])
  @@index([active])
  @@index([closedAt])
  @@index([createdAt])
}

model RescueAlertResponse {
  id        String   @id @default(cuid())
  alertId   String
  userId    String
  respondedAt DateTime @default(now())
  alert     RescueAlert @relation(fields: [alertId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([alertId])
  @@index([userId])
}

model RescueDebriefing {
  id            String   @id @default(cuid())
  title         String
  date          DateTime @default(now())
  location      String
  agentsPresent String[]
  interventionType String
  summary       String
  procedure     String
  result        String
  incidents     String?
  observations  String?
  createdById   String
  createdBy     User     @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([createdById])
  @@index([date])
}

model RescueEvent {
  id          String   @id @default(cuid())
  name        String
  date        DateTime
  startTime   String
  endTime     String
  description String
  location    String
  agentIds    String[]
  isPublic    Boolean  @default(true)

  @@index([date])
  @@index([isPublic])
}

model RescuePatient {
  id          String   @id @default(cuid())
  firstname   String
  lastname    String
  dateOfBirth DateTime
  gender      String
  bloodType   String?
  weight      Decimal? @db.Decimal(5, 2)
  height      Int?     @db.SmallInt
  allergies   String[] @default([])
  medications String[] @default([])
  medicalHistory String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([firstname, lastname])
  @@index([dateOfBirth])
}
